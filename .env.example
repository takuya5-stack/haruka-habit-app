# Supabase PostgreSQL
# Supabase ダッシュボード → Project Settings → Database → Connection string
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-ap-northeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-0-ap-northeast-1.pooler.supabase.com:5432/postgres"

# LINE Messaging API
# LINE Developers → Channel → Messaging API → Channel access token
LINE_CHANNEL_ACCESS_TOKEN="your-line-channel-access-token"
# LINE Developers → あなたのユーザーID（Basic information）
LINE_USER_ID="your-line-user-id"

# Vercel Cron 認証用シークレット（任意の文字列）
CRON_SECRET="your-random-secret-string"

# アプリの公開URL（LINE通知に含める）
NEXT_PUBLIC_APP_URL="https://your-app.vercel.app"
